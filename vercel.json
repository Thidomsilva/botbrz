{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "TELEGRAM_TOKEN": "@telegram_token",
    "TELEGRAM_CHAT_ID": "@telegram_chat_id",
    "PRICE_CHANGE_PCT": "1.5",
    "VOLUME_CHANGE_PCT": "80",
    "CHECK_INTERVAL": "60"
  }
}
